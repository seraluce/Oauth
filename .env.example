# Database
DB_DRIVER=sqlite
DATABASE_URL=file:./local.db

# Redis (optional - leave empty for in-memory fallback)
REDIS_URL=

# Auth Secrets
JWT_SECRET=change-me-to-a-random-64-char-string
SESSION_SECRET=change-me-to-another-random-64-char-string
BCRYPT_ROUNDS=12

# SSO OAuth2 Server
SSO_ISSUER=https://your-domain.pages.dev
SSO_PRIVATE_KEY=
SSO_PUBLIC_KEY=

# OAuth Providers (GitHub)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth Providers (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email
EMAIL_FROM=noreply@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_MODE=console

# Application (生产环境必须使用 https)
NEXT_PUBLIC_APP_URL=https://your-domain.pages.dev
NEXT_PUBLIC_APP_NAME=SSO Auth
NODE_ENV=production

# Security
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Encryption key for OAuth tokens at rest (32 bytes hex)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
